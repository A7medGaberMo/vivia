{
    "extends": "@workspace/typescript-config/base.json",
    "compilerOptions": {
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "esnext",
        "target": "es2020",
        "moduleResolution": "bundler",
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": [
        "embed.ts",
        "vite.config.ts",
        "vite-env.d.ts",
        "*.ts",
        "**/*.ts"
    ],
}